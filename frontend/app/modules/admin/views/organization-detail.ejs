<div class="container-xxl flex-grow-1 container-p-y">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-0">
      <div class="breadcrumb-title">
        <a href="/admin/dashboard"><i class="fas fa-home-alt"></i></a>
      </div>
      <div class="ps-3">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb mb-0 p-0">
            <li class="breadcrumb-item">Admin</li>
            <li class="breadcrumb-item"><a href="/admin/organizations">Organizations</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit</li>
          </ol>
        </nav>
      </div>
    </div>
    <a href="/admin/organizations" class="btn btn-outline-secondary"><i class="ti ti-arrow-left me-1"></i> Back</a>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <% if (typeof errors !== 'undefined' && errors && errors._form) { %>
      <div class="alert alert-danger mb-3" role="alert"><%= errors._form %></div>
      <% } %>
      <% const org = typeof organization !== 'undefined' ? organization : {}; %>
      <% const formOrg = typeof form !== 'undefined' && form ? form : org; %>
      <form id="editOrganizationForm" class="row g-3">
        <%- include('../../../views/partials/inputs/text.ejs', {
          wrapperClass: 'col-12 col-md-6',
          inputLabel: 'Organization Name',
          inputId: 'name',
          isMandatory: true,
          placeholder: 'Enter organization name',
          value: formOrg.name || '',
          errorMessage: typeof errors !== 'undefined' && errors && errors.name ? errors.name : undefined
        }); %>
        <%- include('../../../views/partials/inputs/text.ejs', {
          wrapperClass: 'col-12 col-md-6',
          inputType: 'email',
          inputLabel: 'Email',
          inputId: 'email',
          isMandatory: true,
          placeholder: 'Enter email',
          value: formOrg.email || '',
          errorMessage: typeof errors !== 'undefined' && errors && errors.email ? errors.email : undefined
        }); %>
        <%- include('../../../views/partials/inputs/text.ejs', {
          wrapperClass: 'col-12 col-md-6',
          inputLabel: 'Address',
          inputId: 'address',
          placeholder: 'Enter address',
          value: formOrg.address || '',
          errorMessage: typeof errors !== 'undefined' && errors && errors.address ? errors.address : undefined
        }); %>
        <%- include('../../../views/partials/inputs/text.ejs', {
          wrapperClass: 'col-12 col-md-6',
          inputType: 'tel',
          inputLabel: 'Phone',
          inputId: 'phone',
          placeholder: 'Enter phone number',
          value: formOrg.phone || '',
          errorMessage: typeof errors !== 'undefined' && errors && errors.phone ? errors.phone : undefined
        }); %>
        <div class="col-12 col-md-6">
          <label class="form-label">Status</label>
          <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" id="isActive" name="isActive" <%= (formOrg.isActive !== false && formOrg.isActive !== 'false') ? 'checked' : '' %>>
            <label class="form-check-label" for="isActive">Active</label>
          </div>
        </div>
        <div class="col-12 col-md-6">
          <label class="form-label">Verification</label>
          <% if (org.isVerified) { %>
          <span class="badge bg-success"><i class="ti ti-circle-check me-1"></i> Verified</span>
          <% } else { %>
          <span class="badge bg-warning text-dark"><i class="ti ti-clock me-1"></i> Pending</span>
          <button type="button" class="btn btn-sm btn-primary ms-2" id="btnVerifyOrg">Verify Organization</button>
          <% } %>
        </div>
        <div class="col-12 mt-2">
          <small class="text-muted">Created: <%= org.createdAt ? new Date(org.createdAt).toLocaleDateString() : '—' %></small>
        </div>
        <div class="col-12">
          <button type="submit" class="btn btn-primary"><i class="ti ti-device-floppy me-1"></i> Update Organization</button>
          <a href="/admin/organizations" class="btn btn-outline-secondary ms-2">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
(function () {
  var btnVerify = document.getElementById('btnVerifyOrg');
  if (btnVerify) {
    btnVerify.addEventListener('click', function() {
      if (typeof postForm === 'function') {
        postForm('/admin/organizations/' + '<%= organization && organization.id ? organization.id : "" %>' + '/verify', new URLSearchParams(), null, 'POST');
      }
    });
  }

  var form = document.getElementById('editOrganizationForm');
  if (!form) return;
  var orgId = '<%= organization && organization.id ? organization.id : "" %>';
  var nameEl = document.getElementById('name');
  var emailEl = document.getElementById('email');
  var addressEl = document.getElementById('address');
  var phoneEl = document.getElementById('phone');
  var isActiveEl = document.getElementById('isActive');
  var nameErr = document.getElementById('nameError');
  var emailErr = document.getElementById('emailError');

  function showError(el, msg) {
    if (el) { el.textContent = msg; el.style.display = msg ? 'block' : 'none'; }
  }

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var name = (nameEl && nameEl.value) ? nameEl.value.trim() : '';
    var email = (emailEl && emailEl.value) ? emailEl.value.trim() : '';

    var errors = {};
    if (!name) errors.name = 'Organization name is required';
    if (!email) errors.email = 'Email is required';
    else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) errors.email = 'Please enter a valid email';

    showError(nameErr, errors.name || '');
    showError(emailErr, errors.email || '');

    if (Object.keys(errors).length > 0) return;

    var params = new URLSearchParams();
    params.append('name', name);
    params.append('email', email);
    if (addressEl && addressEl.value) params.append('address', addressEl.value.trim());
    if (phoneEl && phoneEl.value) params.append('phone', phoneEl.value.trim());
    params.append('isActive', (isActiveEl && isActiveEl.checked) ? 'true' : 'false');

    if (typeof postForm === 'function') {
      postForm('/admin/organizations/' + orgId, params, null, 'PUT');
    } else {
      form.submit();
    }
  });
})();
</script>
