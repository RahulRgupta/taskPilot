<div class="container-xxl flex-grow-1 container-p-y">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-0">
      <div class="breadcrumb-title">
        <a href="/employee/dashboard"><i class="fas fa-home-alt"></i></a>
      </div>
      <div class="ps-3">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb mb-0 p-0">
            <li class="breadcrumb-item active" aria-current="page">My Projects</li>
          </ol>
        </nav>
      </div>
    </div>
  </div>

  <% if (projects && projects.length > 0) { %>
  <div class="row g-4">
    <% projects.forEach(function(p) { %>
    <div class="col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <h5 class="card-title mb-2"><%= p.name %></h5>
          <p class="card-text text-muted small mb-3"><%= p.description || 'No description' %></p>
          <div class="d-flex gap-3 mb-3">
            <small class="text-muted"><i class="ti ti-users me-1"></i> <%= p.employees ? p.employees.length : 0 %> members</small>
            <small class="text-muted"><i class="ti ti-subtask me-1"></i> <%= p._count ? p._count.tasks : 0 %> tasks</small>
          </div>
        </div>
        <div class="card-footer bg-transparent border-top">
          <a href="/employee/projects/<%= p.id %>/tasks" class="btn btn-sm btn-primary w-100">
            <i class="ti ti-subtask me-1"></i> Open Task Board
          </a>
        </div>
      </div>
    </div>
    <% }); %>
  </div>
  <% } else { %>
  <div class="card">
    <div class="card-body text-center py-5">
      <i class="ti ti-folder-off" style="font-size: 3rem; color: #ccc;"></i>
      <p class="text-muted mt-3 mb-0">No projects assigned to you yet.</p>
    </div>
  </div>
  <% } %>
</div>
