<div class="container-xxl flex-grow-1 container-p-y">
  <div class="d-flex align-items-center mb-4">
    <a href="/manager/projects" class="btn btn-outline-secondary btn-sm me-2"><i class="ti ti-arrow-left"></i></a>
    <h4 class="fw-bold mb-0"><span class="text-muted fw-light">Manager /</span> <%= project.name %></h4>
  </div>

  <div class="card mb-4">
    <div class="card-body d-flex justify-content-between align-items-start">
      <div>
        <h5 class="card-title"><%= project.name %></h5>
        <p class="text-muted mb-0"><%= project.description || 'No description.' %></p>
        <p class="small text-muted mt-2 mb-0">
          Created by <%= project.createdBy ? (project.createdBy.name || project.createdBy.email) : '—' %>
          on <%= new Date(project.createdAt).toLocaleDateString() %>
        </p>
      </div>
      <a href="/manager/projects/<%= project.id %>/tasks" class="btn btn-outline-primary btn-sm">
        <i class="ti ti-subtask me-1"></i> Task Board
      </a>
    </div>
  </div>

  <div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
      <h5 class="mb-0">Assign team to this project</h5>
    </div>
    <div class="card-body">
      <p class="text-muted small mb-4">Search and select managers and/or employees to add to this project.</p>

      <%
        var optionsForSelect = typeof teamOptions !== 'undefined' && teamOptions ? teamOptions : [];
        if (optionsForSelect.length === 0 && (typeof allManagers !== 'undefined' || typeof allEmployees !== 'undefined')) {
          optionsForSelect = [];
          (typeof allManagers !== 'undefined' && allManagers ? allManagers : []).forEach(function(p) { optionsForSelect.push({ id: p.id, name: (p.name || p.email) + ' (Manager)' }); });
          (typeof allEmployees !== 'undefined' && allEmployees ? allEmployees : []).forEach(function(p) { optionsForSelect.push({ id: p.id, name: (p.name || p.email) + ' (Employee)' }); });
        }
      %>
      <% if (optionsForSelect.length > 0) { %>
      <form action="/manager/projects/<%= project.id %>/employees" method="POST">
        <%- include('../../../views/partials/inputs/multi-select-search.ejs', {
          wrapperClass: 'col-12 mb-3',
          inputLabel: 'Managers & employees',
          inputId: 'employeeIds',
          isMultiple: true,
          placeholder: 'Search by name or email...',
          inputOptions: optionsForSelect,
          value: typeof assignedIds !== 'undefined' ? (assignedIds || []) : []
        }); %>
        <button type="submit" class="btn btn-primary mt-2"><i class="ti ti-device-floppy me-1"></i> Save assignments</button>
      </form>
      <% } else { %>
      <p class="text-muted mb-0">No managers or employees in this organization. Add users from the Users section first.</p>
      <% } %>
    </div>
  </div>

  <% if (project.employees && project.employees.length > 0) { %>
  <div class="card mt-4">
    <div class="card-header">
      <h5 class="mb-0">Currently assigned (<%= project.employees.length %>)</h5>
    </div>
    <div class="table-responsive">
      <table class="table table-hover table-striped mb-0">
        <thead class="table-light">
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
          </tr>
        </thead>
        <tbody>
          <% project.employees.forEach(pe => { %>
          <tr>
            <td><%= pe.user ? (pe.user.name || '—') : '—' %></td>
            <td><%= pe.user ? pe.user.email : '—' %></td>
            <td>
              <% if (pe.user && pe.user.role === 'MANAGER') { %>
              <span class="badge bg-primary">Manager</span>
              <% } else { %>
              <span class="badge bg-info">Employee</span>
              <% } %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
  <% } %>
</div>
