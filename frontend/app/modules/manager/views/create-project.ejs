<div class="container-xxl flex-grow-1 container-p-y">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div class="page-breadcrumb d-none d-sm-flex align-items-center mb-0">
      <div class="breadcrumb-title">
        <a href="/manager/dashboard"><i class="fas fa-home-alt"></i></a>
      </div>
      <div class="ps-3">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb mb-0 p-0">
            <li class="breadcrumb-item">Manager</li>
            <li class="breadcrumb-item"><a href="/manager/projects">Projects</a></li>
            <li class="breadcrumb-item active" aria-current="page">Create Project</li>
          </ol>
        </nav>
      </div>
    </div>
    <a href="/manager/projects" class="btn btn-outline-secondary"><i class="ti ti-arrow-left me-1"></i> Back</a>
  </div>
  <div class="card">
    <div class="card-body">
      <% if (typeof errors !== 'undefined' && errors && errors._form) { %>
      <div class="alert alert-danger mb-3" role="alert"><%= errors._form %></div>
      <% } %>
      <form id="createProjectForm" action="/manager/projects" method="POST" class="row g-3">
        <%- include('../../../views/partials/inputs/text.ejs', {
          wrapperClass: 'col-12 col-md-6',
          inputLabel: 'Project name',
          inputId: 'name',
          isMandatory: true,
          placeholder: 'e.g. Website Redesign',
          value: typeof form !== 'undefined' && form && form.name ? form.name : '',
          errorMessage: typeof errors !== 'undefined' && errors && errors.name ? errors.name : undefined
        }); %>
        <%- include('../../../views/partials/inputs/textarea.ejs', {
          wrapperClass: 'col-12',
          inputLabel: 'Description',
          inputId: 'description',
          rows: 3,
          placeholder: 'Brief description of the project',
          value: typeof form !== 'undefined' && form && form.description ? form.description : '',
          errorMessage: typeof errors !== 'undefined' && errors && errors.description ? errors.description : undefined
        }); %>
        <%- include('../../../views/partials/inputs/select.ejs', {
          wrapperClass: 'col-12 col-md-6',
          inputLabel: 'Status',
          inputId: 'status',
          value: typeof form !== 'undefined' && form && form.status ? form.status : 'PLANNING',
          inputOptions: [
            { id: 'PLANNING', name: 'Planning' },
            { id: 'ACTIVE', name: 'Active' },
            { id: 'ON_HOLD', name: 'On Hold' },
            { id: 'COMPLETED', name: 'Completed' }
          ]
        }); %>
        <%- include('../../../views/partials/inputs/select.ejs', {
          wrapperClass: 'col-12 col-md-6',
          inputLabel: 'Priority',
          inputId: 'priority',
          value: typeof form !== 'undefined' && form && form.priority ? form.priority : 'MEDIUM',
          inputOptions: [
            { id: 'LOW', name: 'Low' },
            { id: 'MEDIUM', name: 'Medium' },
            { id: 'HIGH', name: 'High' }
          ]
        }); %>
        <%- include('../../../views/partials/inputs/text.ejs', {
          wrapperClass: 'col-12 col-md-6',
          inputLabel: 'Start date',
          inputId: 'startDate',
          inputType: 'date',
          placeholder: '',
          value: typeof form !== 'undefined' && form && form.startDate ? form.startDate : '',
          errorMessage: typeof errors !== 'undefined' && errors && errors.startDate ? errors.startDate : undefined
        }); %>
        <%- include('../../../views/partials/inputs/text.ejs', {
          wrapperClass: 'col-12 col-md-6',
          inputLabel: 'End date',
          inputId: 'endDate',
          inputType: 'date',
          placeholder: '',
          value: typeof form !== 'undefined' && form && form.endDate ? form.endDate : '',
          errorMessage: typeof errors !== 'undefined' && errors && errors.endDate ? errors.endDate : undefined
        }); %>
        <div class="col-12">
          <button type="submit" class="btn btn-primary">Create Project</button>
          <a href="/manager/projects" class="btn btn-outline-secondary ms-2">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
(function () {
  var form = document.getElementById('createProjectForm');
  if (!form) return;
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var nameEl = document.getElementById('name');
    var descEl = document.getElementById('description');
    var statusEl = document.getElementById('status');
    var priorityEl = document.getElementById('priority');
    var startDateEl = document.getElementById('startDate');
    var endDateEl = document.getElementById('endDate');
    var name = (nameEl && nameEl.value) ? nameEl.value.trim() : '';
    var params = new URLSearchParams();
    params.append('name', name);
    if (descEl && descEl.value) params.append('description', descEl.value.trim());
    if (statusEl && statusEl.value) params.append('status', statusEl.value);
    if (priorityEl && priorityEl.value) params.append('priority', priorityEl.value);
    if (startDateEl && startDateEl.value) params.append('startDate', startDateEl.value);
    if (endDateEl && endDateEl.value) params.append('endDate', endDateEl.value);
    if (typeof postForm === 'function') {
      postForm('/manager/projects', params);
    } else {
      form.submit();
    }
  });
})();
</script>
