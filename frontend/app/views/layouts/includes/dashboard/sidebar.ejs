    <!-- <li class="menu-item" data-path="/organization/managers/new">
      <a href="/organization/managers/new" class="menu-link">
        <i class="menu-icon tf-icons ti ti-user-plus"></i>
        <div data-i18n="Create Manager">Create Manager</div>
      </a>
    </li> -->
    <!-- <li class="menu-item" data-path="/organization/employees/new">
      <a href="/organization/employees/new" class="menu-link">
        <i class="menu-icon tf-icons ti ti-user-plus"></i>
        <div data-i18n="Create Employee">Create Employee</div>
      </a>
    </li> -->
    <% } %>

