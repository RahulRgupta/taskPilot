  </ul>
</aside>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var currentPath = window.location.pathname;
    var menuItems = document.querySelectorAll('.menu-item');
    var deepestMatch = null;
    menuItems.forEach(function (item) {
      var itemPath = item.getAttribute('data-path');
      if (currentPath === itemPath) {
        item.classList.add('active');
        deepestMatch = item;
      } else if (itemPath && currentPath.startsWith(itemPath) && !deepestMatch) {
        item.classList.add('active');
        deepestMatch = item;
      }
    });
    if (deepestMatch) {
      var parent = deepestMatch.parentElement;
      while (parent && parent.classList.contains('menu-sub')) {
        parent.parentElement.classList.add('active', 'open');
        parent = parent.parentElement ? parent.parentElement.parentElement : null;
      }
    }
  });
</script>
