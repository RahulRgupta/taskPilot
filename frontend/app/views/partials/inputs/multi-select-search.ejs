<!-- Include Tom Select CSS/JS -->
<link href="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/css/tom-select.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/js/tom-select.complete.min.js"></script>

<style>
    /* Clean UI fix for single select */
    .ts-wrapper.single .ts-control {
        height: 38px;
        border: 1px solid #ced4da;
        border-radius: 0.375rem;
        font-size: 1rem;
        padding: 0.375rem 0.75rem;
    }

    /* Clean UI fix for multi select */
    .ts-wrapper.multi .ts-control {
        min-height: 38px;
        border: 1px solid #ced4da;
        border-radius: 0.375rem;
        font-size: 1rem;
        padding: 0.375rem 0.75rem;
    }

    .ts-dropdown {
        border-radius: 0.375rem;
        z-index: 9999;
    }

    .ts-control input {
        margin: 0 !important;
        padding: 0 !important;
    }

    /* Multi-select item styling */
    .ts-wrapper.multi .ts-control>div {
        background: #007bff;
        color: white;
        border: none;
        border-radius: 0.25rem;
        margin: 2px;
        padding: 2px 8px;
    }

    .ts-wrapper.multi .ts-control>div .remove {
        color: white;
        margin-left: 5px;
        font-weight: bold;
    }
</style>

<div class="<%= wrapperClass %> position-relative">
    <% if (typeof inputLabel !== 'undefined' && inputLabel) { %>
    <label class="form-label">
        <%= inputLabel %>
        <% if (typeof isMandatory !== 'undefined' && isMandatory === true) { %>
        <span class="text-danger">*</span>
        <% } %>
    </label>
    <% } %>

    <select id="<%= inputId %>"
        name="<%= inputId %><%= (typeof isMultiple !== 'undefined' && isMultiple) ? '[]' : '' %>"
        class="<%= typeof customClass !== 'undefined' ? customClass : '' %>"
        <%= (typeof isMultiple !== 'undefined' && isMultiple) ? 'multiple' : '' %>>
        <% if (!(typeof isMultiple !== 'undefined' && isMultiple)) { %>
        <option value="">Select option</option>
        <% } %>

        <% if (typeof inputOptions !== 'undefined' && inputOptions.length > 0) { %>
        <% inputOptions.forEach(function(element) { %>
        <% 
          var isSelected = false;
          if (typeof isMultiple !== 'undefined' && isMultiple) {
            isSelected = Array.isArray(value) && value.includes(element.id);
          } else {
            isSelected = element.id == value;
          }
        %>
        <option value="<%= element.id %>" <%= element.disabled ? 'disabled' : '' %> <%= isSelected ? "selected" : "" %>>
            <%= element.name %>
        </option>
        <% }); %>
        <% } %>
    </select>

    <label for="<%= inputId.replace('[]', '') %>" class="invalid-feedback"></label>
</div>

<script>
    (function () {
        var selector = "#<%= inputId %>";
        var allowCreate = <%= (typeof allowCreate !== 'undefined' && allowCreate) ? 'true' : 'false' %>;
        var placeholder = '<%= (typeof placeholder !== "undefined" && placeholder) ? placeholder : "Search options..." %>';
        var isMultiple = <%= (typeof isMultiple !== 'undefined' && isMultiple) ? 'true' : 'false' %>;

        var maxItems;
<% if (typeof maxItems !== 'undefined') { %>
            maxItems = <%= maxItems %>;
<% } else { %>
            maxItems = isMultiple ? null : 1;
<% } %>
  
  var closeAfterSelect;
<% if (typeof closeAfterSelect !== 'undefined') { %>
            closeAfterSelect = <%= closeAfterSelect ? 'true' : 'false' %>;
<% } else { %>
            closeAfterSelect = !isMultiple;
<% } %>

  var options = {
            create: allowCreate,
            createOnBlur: allowCreate,
            placeholder: placeholder,
            maxItems: maxItems,
            closeAfterSelect: closeAfterSelect
        };

<% if (typeof searchField !== 'undefined' && searchField) { %>
            options.searchField = '<%= searchField %>';
<% } %>

<% if (typeof sortField !== 'undefined' && sortField) { %>
            options.sortField = '<%= sortField %>';
<% } %>

<% if (typeof plugins !== 'undefined' && plugins) { %>
            options.plugins = <% - JSON.stringify(plugins) %>;
<% } else { %>
  if (isMultiple) {
                options.plugins = ['remove_button'];
            }
<% } %>

  if (allowCreate) {
            options.createFilter = function (input) {
                var normalized = (input || '').trim().toLowerCase();
                var opts = this.options ? Object.values(this.options) : [];
                return !opts.some(function (opt) { return ((opt.text || '') + "").trim().toLowerCase() === normalized; });
            };
            options.render = {
                option_create: function (data, escape) {
                    return '<div class="create">Add new: <strong>' + escape(data.input) + '</strong></div>';
                }
            };
        }

        var tomSelect = new TomSelect(selector, options);

<% if (typeof storeReference !== 'undefined' && storeReference) { %>
            window['tomSelect_<%= inputId.replace(/[^a-zA-Z0-9]/g, '_') %>'] = tomSelect;
<% } %>

<% if (typeof onItemAdd !== 'undefined' && onItemAdd) { %>
            tomSelect.on('item_add', function (value, item) {
                console.log('Item added:', value);
            });
<% } %>

<% if (typeof onItemRemove !== 'undefined' && onItemRemove) { %>
            tomSelect.on('item_remove', function (value) {
                console.log('Item removed:', value);
            });
<% } %>

<% if (typeof onChange !== 'undefined' && onChange) { %>
            tomSelect.on('change', function (value) {
                console.log('Selection changed:', value);
            });
<% } %>

})();
</script>