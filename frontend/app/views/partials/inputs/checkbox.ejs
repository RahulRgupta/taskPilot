<div class="<%= wrapperClass %>">
  
  
  <% if ( typeof inputLabel !== 'undefined' && inputLabel ) { %>
    <label class="form-label"><%= inputLabel %>
    
    <% if (typeof isMandatory !== 'undefined' && isMandatory === true) { %>
          <span class="text-danger">*</span>
        <% } %>
    
    </label>
    <% } %>
  
  <% const selected = typeof value === 'string' && value.length > 1 ? value.split(',') : [value]; %>

  <% inputOptions.forEach(element => { %>
    <div class="form-check">
      <input 
        class="form-check-input" 
        type="checkbox" 
        id="<%= element.id %>" 
        name="<%= inputId %>[]" 
        value="<%= element.id %>" 
        <%= selected.includes(element.id.toString()) ? 'checked' : '' %> >
      <label class="form-check-label" for="<%= element.id %>"><%= element.name %></label>
    </div>
  <% }) %>

  <% if ( typeof hintText !== 'undefined' && hintText ) { %>
    <label class="mt-2">Hint: <%= hintText %></label>
  <% } %>
 
  <label for="<%= inputId %>" class="invalid-feedback"></label>  
</div>